enable=all
source-path=SCRIPTDIR
# SC2154: referenced but not assigned (false positives for externally-set vars)
# SC2250: style — prefer braces (purely cosmetic, not a correctness issue)
# SC2310: info — function in conditional disables set -e (intentional pattern)
# SC2249: info — case missing default (intentional where exhaustive cases exist)
# SC2312: info — command substitution masks return value (intentional where noted)
disable=SC2154,SC2250,SC2310,SC2249,SC2312

# If you're having issues with shellcheck following source, disable the errors via:
# disable=SC1090
# disable=SC1091
